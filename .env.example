# Supabase 配置
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# R2 存储配置
VITE_R2_ACCOUNT_ID=your_r2_account_id
VITE_R2_ACCESS_KEY_ID=your_r2_access_key_id
VITE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
VITE_R2_BUCKET_NAME=joint-knowledge-base
VITE_R2_PUBLIC_DOMAIN=https://jkb.zyhorg.cn

# 应用配置
VITE_APP_NAME=CollabDocs
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production
VITE_MAX_FILE_SIZE=500

# 实时协作服务端地址（Cloudflare Workers）
# 部署后替换为 Worker 的 wss:// 地址
VITE_COLLAB_SERVER_URL=wss://collab-docs-server.your-workers.dev
